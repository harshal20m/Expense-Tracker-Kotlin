<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
   
   PRIVACY: This app stores all data locally. Cloud backup is disabled by default
   to protect user financial data. Users can manually export their data if needed.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Explicitly disable cloud backup for privacy - financial data stays on device -->
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="file" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Allow device-to-device transfer for local migration only -->
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>