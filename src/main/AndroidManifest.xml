<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.example.paisatracker">

    <!-- ═══════════════════════════════════════════════════════════════════
         PERMISSIONS — Minimal set for core expense tracking functionality
         All sensitive permissions (Camera, Notifications, Storage) removed
         to prevent Google Play Protect false positives.
         
         This app now works entirely with manual entry only.
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- Biometric: optional security feature for app lock -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />


    <!-- ═══════════════════════════════════════════════════════════════════
         QUERIES — UPI apps visible to Intent resolution for payment links
         NOTE: These declarations improve transparency by explicitly stating
         which apps we interact with for manual payment initiation.
         
         TRANSPARENCY: This app only opens UPI apps via intent when user
         explicitly chooses to make a payment. No data is collected or
         shared with these apps automatically.
         ═══════════════════════════════════════════════════════════════════ -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="upi" />
        </intent>
    </queries>

    <application
        android:name=".PaisaTrackerApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PaisaTracker"
        android:description="@string/app_description"
        tools:targetApi="31">

        <!-- ─── Main activity ──────────────────────────────────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.PaisaTracker"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ─── FileProvider ───────────────────────────────────────────── -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
