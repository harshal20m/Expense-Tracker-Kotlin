<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.example.paisatracker">

    <!-- ═══════════════════════════════════════════════════════════════════
         PERMISSIONS — declare only what's strictly needed
         Play Protect scores every permission. Remove unused ones entirely.
         ═══════════════════════════════════════════════════════════════════ -->


    <!-- Storage: images for assets (scoped storage, no WRITE needed on API 29+) -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"
        tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- Notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Biometric -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />


    <!-- ═══════════════════════════════════════════════════════════════════
         QUERIES — UPI apps visible to Intent resolution
         NOTE: These declarations improve transparency and reduce Play Protect
         false positives by explicitly stating which apps we interact with.
         ═══════════════════════════════════════════════════════════════════ -->
    <queries>
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="upi" />
        </intent>
        <!-- UPI apps - explicitly declared for transparency -->
        <package android:name="com.google.android.apps.nbu.paisa.user" />
        <package android:name="com.phonepe.app" />
        <package android:name="net.one97.paytm" />
        <package android:name="in.org.npci.upiapp" />
        <package android:name="in.amazon.mShop.android.shopping" />
    </queries>

    <application
        android:name=".PaisaTrackerApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PaisaTracker"
        android:description="@string/app_description"
        tools:targetApi="31">

        <!-- ─── Main activity ──────────────────────────────────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.PaisaTracker"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>


        <!-- ─── FileProvider ───────────────────────────────────────────── -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>